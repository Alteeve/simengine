@@ -308,11 +308,8 @@ class PDUStateManager(state_api.IPDUStateManager, StateManager):
 class OutletStateManager(state_api.IOutletStateManager, StateManager):
     """Handles state logic for outlet asset"""
 
-    class OutletState(Enum):
-        """Outlet States (oid)"""
